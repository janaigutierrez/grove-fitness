# API Configuration
# Copy this file to .env and update with your values

# Environment (development or production)
EXPO_PUBLIC_ENV=development

# ===== DEVELOPMENT URLS =====
# Backend API URL for web (localhost)
EXPO_PUBLIC_API_URL_WEB=http://localhost:5000/api

# Backend API URL for mobile (use your local IP address)
# Find your IP with: ipconfig (Windows) or ifconfig (Mac/Linux)
EXPO_PUBLIC_API_URL_MOBILE=http://192.168.1.138:5000/api

# ===== PRODUCTION URL =====
# Backend API URL for production (Railway, Render, Fly.io, etc.)
# Update this with your deployed backend URL
EXPO_PUBLIC_API_URL_PRODUCTION=https://your-backend-url.railway.app/api
